rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function verified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function active() {
      return verified()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && profile().data.active == true;
    }

    function hasRole(role) {
      return active() && profile().data.roles is list && role in profile().data.roles;
    }

    function hasAnyRole(roles) {
      return active() && profile().data.roles is list && profile().data.roles.hasAny(roles);
    }

    function isOwner() { return hasRole('owner'); }
    function isManager() { return hasRole('manager'); }
    function canOperateOrders() { return hasAnyRole(['owner', 'manager', 'cashier', 'waiter', 'kitchen']); }
    function canCreateOrders() { return hasAnyRole(['owner', 'manager', 'cashier', 'waiter']); }
    function canBill() { return hasAnyRole(['owner', 'manager', 'cashier']); }
    function canManageCatalog() { return hasAnyRole(['owner', 'manager']); }
    function canManageClients() { return hasAnyRole(['owner', 'manager', 'cashier']); }

    function ownsOpenCashSession(sessionId) {
      return sessionId is string
        && sessionId.size() > 0
        && exists(/databases/$(database)/documents/cashSessions/$(sessionId))
        && get(/databases/$(database)/documents/cashSessions/$(sessionId)).data.status == 'open'
        && get(/databases/$(database)/documents/cashSessions/$(sessionId)).data.openedBy == request.auth.uid;
    }

    function validMoney(value) {
      return value is int && value >= 0 && value <= 100000000000;
    }

    function validOrderTransition(before, after) {
      return (before == 'pending' && after in ['preparing', 'cancelled'])
        || (before == 'preparing' && after in ['pending', 'ready', 'cancelled'])
        || (before == 'ready' && after in ['preparing', 'served', 'cancelled'])
        || (before == 'served' && after in ['pending_payment', 'cancelled'])
        || (before == 'pending_payment' && after in ['closed', 'cancelled']);
    }

    function orderChangedOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status', 'revision', 'updatedAt', 'updatedBy', 'statusChangedAt',
        'cancelledAt', 'cancelledBy', 'linkedInvoiceId', 'closedAt', 'closedBy'
      ]);
    }

    match /users/{userId} {
      allow get: if verified() && request.auth.uid == userId || isOwner();
      allow list: if isOwner();
      allow create: if isOwner()
        && request.resource.data.roles is list
        && request.resource.data.roles.hasOnly(['owner', 'manager', 'cashier', 'waiter', 'kitchen'])
        && request.resource.data.active is bool;
      allow update: if isOwner()
        && request.auth.uid != userId
        && request.resource.data.roles is list
        && request.resource.data.roles.hasOnly(['owner', 'manager', 'cashier', 'waiter', 'kitchen'])
        && request.resource.data.active is bool;
      allow delete: if false;
    }

    match /settings/{settingId} {
      allow read: if active();
      allow create, update: if isOwner();
      allow delete: if false;
    }

    match /counters/{counterId} {
      allow read, create, update: if canBill();
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if active();
      allow create: if canManageCatalog()
        && request.resource.data.name is string
        && validMoney(request.resource.data.priceCents)
        && validMoney(request.resource.data.costCents)
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0;
      allow update: if canManageCatalog() || (
        canBill()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt', 'updatedBy'])
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0
        && request.resource.data.stock < resource.data.stock
        && request.resource.data.updatedBy == request.auth.uid
      );
      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read, create, update: if canManageClients();
      allow delete: if false;
    }

    match /tables/{tableId} {
      allow read: if active();
      allow create: if isOwner();
      allow update: if canCreateOrders()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentOrderId', 'status', 'updatedAt'])
        && request.resource.data.status in ['available', 'occupied'];
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if canOperateOrders();
      allow create: if canCreateOrders()
        && request.resource.data.status == 'pending'
        && request.resource.data.revision == 1
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && validMoney(request.resource.data.subtotalCents)
        && validMoney(request.resource.data.taxCents)
        && validMoney(request.resource.data.totalCents);
      allow update: if canOperateOrders()
        && orderChangedOnly()
        && request.resource.data.revision == resource.data.revision + 1
        && request.resource.data.updatedBy == request.auth.uid
        && validOrderTransition(resource.data.status, request.resource.data.status)
        && (
          isOwner() || isManager()
          || (hasRole('kitchen') && (
            (resource.data.status == 'pending' && request.resource.data.status == 'preparing')
            || (resource.data.status == 'preparing' && request.resource.data.status == 'ready')
          ))
          || (hasRole('waiter') && request.resource.data.status in ['served', 'pending_payment', 'cancelled'])
          || (hasRole('cashier') && request.resource.data.status == 'closed')
        );
      allow delete: if false;

      match /events/{eventId} {
        allow read: if canOperateOrders();
        allow create: if canOperateOrders()
          && request.resource.data.orderId == orderId
          && request.resource.data.actorId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /invoices/{invoiceId} {
      allow read: if canBill();
      allow create: if canBill()
        && request.resource.data.documentType in ['invoice', 'quote', 'proforma']
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && validMoney(request.resource.data.subtotalCents)
        && validMoney(request.resource.data.taxCents)
        && validMoney(request.resource.data.totalCents)
        && validMoney(request.resource.data.paidCents)
        && request.resource.data.paidCents <= request.resource.data.totalCents;
      allow update: if (
        canBill()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paidCents', 'status', 'updatedAt', 'updatedBy'])
        && request.resource.data.paidCents >= resource.data.paidCents
        && request.resource.data.paidCents <= resource.data.totalCents
        && request.resource.data.status in ['partial', 'paid']
        && request.resource.data.updatedBy == request.auth.uid
      ) || (
        (isOwner() || isManager())
        && resource.data.status != 'cancelled'
        && resource.data.paidCents == 0
        && request.resource.data.status == 'cancelled'
        && request.resource.data.cancellationReason is string
        && request.resource.data.cancellationReason.size() >= 3
        && request.resource.data.cancelledBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'cancellationReason', 'cancelledAt', 'cancelledBy', 'updatedAt', 'updatedBy'
        ])
      );
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if canBill();
      allow create: if canBill()
        && validMoney(request.resource.data.amountCents)
        && request.resource.data.amountCents > 0
        && request.resource.data.createdBy == request.auth.uid
        && ownsOpenCashSession(request.resource.data.cashSessionId)
        && request.resource.data.method in ['cash', 'card', 'transfer', 'check', 'credit'];
      allow update, delete: if false;
    }

    match /cashSessions/{sessionId} {
      allow read: if canBill();
      allow create: if canBill()
        && request.resource.data.openedBy == request.auth.uid
        && request.resource.data.status == 'open'
        && validMoney(request.resource.data.openingCents);
      allow update: if canBill()
        && resource.data.status == 'open'
        && request.resource.data.status == 'closed'
        && (resource.data.openedBy == request.auth.uid || isOwner() || isManager())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'expectedCents', 'closingCents', 'varianceCents', 'closingNotes', 'closedAt', 'closedBy'
        ])
        && validMoney(request.resource.data.expectedCents)
        && request.resource.data.closingCents is int
        && request.resource.data.closingCents >= 0
        && request.resource.data.varianceCents == request.resource.data.closingCents - request.resource.data.expectedCents
        && request.resource.data.closedBy == request.auth.uid;
      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isOwner() || isManager();
      allow create: if active()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.action is string;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
